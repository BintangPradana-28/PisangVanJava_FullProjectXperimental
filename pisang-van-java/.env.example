# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/pisang_van_java?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/pisang_van_java"

# ── Authentication ───────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Midtrans Payment Gateway ─────────────────────────────
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"

# ── Upstash Redis (Rate Limiting + Sessions) ─────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Cloudinary (Media Storage) ───────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Resend (Transactional Email) ─────────────────────────
RESEND_API_KEY="re_your-api-key"

# ── Fonnte (WhatsApp API) ────────────────────────────────
FONNTE_API_TOKEN="your-fonnte-token"

# ── Biteship (Shipping) ──────────────────────────────────
BITESHIP_API_KEY="your-biteship-key"

# ── PostHog (Analytics) ─────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_your-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── Doppler (Secrets Management - optional) ─────────────
DOPPLER_TOKEN=""

# ── Build ────────────────────────────────────────────────
SKIP_ENV_VALIDATION="false"
