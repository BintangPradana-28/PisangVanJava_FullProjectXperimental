# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/pisang_van_java?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/pisang_van_java"

# ── Authentication ───────────────────────────────────────
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ── Midtrans Payment Gateway ─────────────────────────────
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"

# ── Upstash Redis (Rate Limiting + Sessions) ─────────────
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Cloudinary (Media Storage) ───────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Resend (Transactional Email) ─────────────────────────
RESEND_API_KEY="re_your-api-key"

# ── Fonnte (WhatsApp API) ────────────────────────────────
FONNTE_API_TOKEN="your-fonnte-token"

# ── Biteship (Shipping) ──────────────────────────────────
BITESHIP_API_KEY="your-biteship-key"

# ── PostHog (Analytics) ─────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_your-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── Web Push Notifications (VAPID) ───────────────────────
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="your-email-for-vapid-reports"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="same-as-vapid-public-key"

# ── Database Encryption & Backups ────────────────────────
BACKUP_ENCRYPTION_KEY="32-byte-hex-string"

# ── Doppler (Secrets Management - optional) ─────────────
DOPPLER_TOKEN=""

# ── Sentry (Telemetry) ──────────────────────────────────
SENTRY_DSN="your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# ── Build ────────────────────────────────────────────────
SKIP_ENV_VALIDATION="false"
