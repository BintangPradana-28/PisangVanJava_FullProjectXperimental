ignore-scripts=false
# Semgrep: npm-missing-minimum-release-age — wait 7 days before resolving newly-
# published package versions. Unit is DAYS for npm's setting (unlike pnpm's
# minimumReleaseAge below, which uses minutes) — confirmed against Semgrep's own
# remediation text ("min-release-age = 7"), not assumed.
min-release-age=7
