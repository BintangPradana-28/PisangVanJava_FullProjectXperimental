{
  "name": "pisang-goreng-van-java",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "browserslist": [
    "last 2 years",
    "not dead",
    "not ie 11"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "dev:doppler": "doppler run -- next dev",
    "build": "prisma generate && next build",
    "build:doppler": "doppler run -- prisma generate && doppler run -- next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "prepare": "cd .. && husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "format": "biome format --write .",
    "lint:biome": "biome lint .",
    "check": "biome check --write .",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org pisang-van-java --project pisang-van-java .next && sentry-cli sourcemaps upload --org pisang-van-java --project pisang-van-java .next",
    "secretlint": "secretlint \"**/*\"",
    "audit:fix": "pnpm audit --fix",
    "depcheck": "depcheck",
    "env:check": "SKIP_ENV_VALIDATION=false node -e \"import('./src/env.ts').then(m => console.log('✅ Env valid:', Object.keys(m.env).length, 'variables'))\""
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --apply --no-errors-on-unmatched",
      "secretlint"
    ],
    "*.{json,md,mdx,css}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "**/.env*": [
      "secretlint"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@hookform/resolvers": "^5.4.0",
