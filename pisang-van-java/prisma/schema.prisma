// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  KITCHEN
  CASHIER
  CUSTOMER
  RESELLER
}

enum OrderStatus {
  PENDING_PAYMENT
  PROCESSING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELED
}

enum ComplaintStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  CHALLENGE
  FAILED
  CANCELED
  EXPIRED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  address       String?
  role          Role      @default(CUSTOMER)
  koinPisang    Int       @default(0) // Gamification (Loyalty Points)

  // Sistem Referral
  referralCode String? @unique // Kode unik milik user (misal: PVJ-BUDI123)
  referredBy   String? // ID user yang mengundang mereka
  hasOrdered   Boolean @default(false) // Penanda apakah user sudah pernah order

  isBanned  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  notificationPrefs Json?   @default("{\"email\":true,\"push\":false,\"promo\":true,\"order\":true}")
  twoFactorEnabled  Boolean @default(false)
  twoFactorSecret   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  sessions    Session[]
  resetTokens ResetToken[]
  favorites   Favorite[]
  reviews     Review[]
  cart        UserCart?
  orders      Order[]
  b2bDeals    B2BDeal[]
  addresses   Address[]
  authLogs    AuthLog[]
  complaints  Complaint[]
  koinLogs    KoinPisangLog[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MenuVariant {
  id                String      @id @default(cuid())
  flavorName        String      @map("nama_varian")
  priceKembung      Int         @default(0)
  priceLumpia       Int         @default(0)
  priceKrispy       Int         @default(0)
  wholesaleKembung  Int         @default(0)
  wholesaleLumpia   Int         @default(0)
  wholesaleKrispy   Int         @default(0)
  harga             Float? // Legacy column
  deskripsi_topping String? // Legacy column
  imageUrl          String?     @map("foto_url")
  isActive          Boolean     @default(true)
  isAvailable       Boolean     @default(true) // Untuk stok harian
  stock             Int         @default(999) // Pessimistic Locking / OCC
  soldCount         Int         @default(0) // Jumlah produk yang sudah terjual
  version           Int         @default(1) // Optimistic Concurrency Control
  isDeleted         Boolean     @default(false) // Untuk Soft Delete
  tags              String[]    @default([]) // Array of string for tagging (e.g., "Manis", "Gurih")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]
  favorites         Favorite[]
  reviews           Review[]

  @@index([flavorName]) // Database Indexing
  @@index([isDeleted])
  @@index([isActive])
  @@map("Product")
}

model StoreBranch {
  id              String   @id @default(cuid())
  nomor_wa        String
  alamat          String
  jam_operasional String
  isDeleted       Boolean  @default(false) // Untuk Soft Delete
  updatedAt       DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
}

model Topping {
  id         String      @id @default(cuid())
  name       String      @unique
  price      Int         @default(2000)
  emoji      String?
  isActive   Boolean     @default(true) // Untuk toggle stok ketersediaan
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]

  @@index([isActive])
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  customerName   String
  customerPhone  String
  totalPrice     Float
  status         OrderStatus @default(PENDING_PAYMENT)
  notes          String?
  source         String      @default("whatsapp") // whatsapp, online, walk-in
  voucherCode    String? // Nullable, if they used a voucher
  discountAmount Float       @default(0) // Total discount applied
  deliveryMethod String      @default("DELIVERY")
  deliveryFee    Float       @default(0)

  // ── Delivery Tracking ──
  courierName    String?     // e.g., "Gojek", "Grab" — persisted from checkout selection
  courierPhone   String?     // Kurir phone number (set by admin/kitchen when assigning)
  etaMinutes     Int?        // Dynamic ETA in minutes (set when status → OUT_FOR_DELIVERY)
  tipAmount      Float       @default(0)
  proofPhotoUrl  String?     // Cloudinary URL — proof of delivery photo
  addressId      String?     // FK to Address model for structured delivery address
  biteshipOrderId String?
  waybillId       String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // -- Midtrans Integration --
  midtransToken         String?
  midtransTransactionId String?   @unique
  payment               Payment?
  confirmedAt           DateTime?

  user       User?       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items      OrderItem[]
  reviews    Review[]
  complaints Complaint[]
  address    Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([addressId])
  @@index([biteshipOrderId])
}

model Voucher {
  id            String   @id @default(cuid())
  code          String   @unique
  discountType  String   @default("PERCENTAGE") // PERCENTAGE atau FIXED
  discountValue Float
  minPurchase   Float    @default(0)
  maxDiscount   Float? // Nullable, if null = unlimited
  startDate     DateTime @default(now())
  endDate       DateTime
  usageLimit    Int      @default(0) // 0 means unlimited
  usedCount     Int      @default(0)
  isActive      Boolean  @default(true)
  applicableTo  String   @default("ALL") // ALL, CUSTOMER, RESELLER
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([code])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  variantId String?
  baseType  String
  quantity  Int
  unitPrice Float
  subtotal  Float

  order    Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant  MenuVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  toppings Topping[]

  @@index([orderId])
  @@index([variantId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. "CREATE", "UPDATE", "DELETE"
  resource   String // e.g. "MenuVariant", "Topping"
  resourceId String
  userId     String? // Who did it (can be null if system)
  details    String? // JSON string of changes
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([resourceId])
  @@index([userId])
  @@index([createdAt])
}

model Complaint {
  id               String          @id @default(cuid())
  userId           String
  orderId          String?
  subject          String
  description      String          @db.Text
  adminResponse    String?         @db.Text
  compensationKoin Int             @default(0)
  status           ComplaintStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  variantId String
  createdAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant MenuVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
  @@index([variantId])
}

model Banner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  badge     String?
  imageUrl  String?
  isActive  Boolean   @default(true)
  linkUrl   String?
  startDate DateTime? // Untuk penjadwalan promo
  endDate   DateTime? // Untuk batas akhir promo
  priority  Int       @default(0) // Untuk urutan carousel
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive])
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  orderId         String
  variantId       String?
  rating          Int // 1-5
  comment         String?
  imageUrl        String?
  isVerifiedBuyer Boolean  @default(false)
  isHidden        Boolean  @default(false) // Moderasi admin — review tersembunyi dari publik
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant MenuVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([userId, orderId]) // Satu user hanya bisa review 1x per order
  @@index([orderId])
  @@index([variantId])
  @@index([userId])
  @@index([createdAt])
}

model UserCart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Json     @default("[]") // JSONB format
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String // e.g., "Rumah", "Kantor"
  fullAddress String
  latitude    Float?
  longitude   Float?
  notes       String? // patokan alamat, e.g. "Depan warung merah"
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([userId])
}

model ContactLead {
  id        String   @id @default(cuid())
  name      String
  message   String
  ipAddress String?
  userAgent String?
  isConsent Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

enum DealStage {
  PROSPECTING
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model B2BDeal {
  id          String    @id @default(cuid())
  companyName String
  contactName String
  phone       String
  email       String?
  dealName    String
  amount      Float?
  stage       DealStage @default(PROSPECTING)
  ownerId     String?
  notes       String?   @db.Text

  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([ownerId])
}

model AuthLog {
  id        String   @id @default(cuid())
  userId    String
  event     String // SIGN_IN, SIGN_OUT, MFA_VERIFY, BAN
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactionId     String?       @unique // Midtrans transaction_id
  midtransOrderId   String        @unique // e.g. "PVJ-{orderId}-{timestamp}"
  status            PaymentStatus @default(PENDING)
  paymentType       String? // "qris", "bank_transfer", dll
  paymentChannel    String? // bank name or qris acquirer
  grossAmount       Decimal       @db.Decimal(15, 2)
  fraudStatus       String?
  settlementTime    DateTime?
  expiryTime        DateTime?
  vaNumber          String?
  acquirer          String?
  currency          String        @default("IDR")
  rawWebhookPayload Json?
  idempotencyKey    String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model KoinPisangLog {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // Jumlah koin (bisa positif/negatif)
  description String   // Deskripsi perubahan (misal: "Referral Bonus", "Redeemed at Checkout", dll)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

